{
  "name": "@planetbee/seller-assistant",
  "version": "2026.3.20",
  "description": "Seller assistant plugin for OpenClaw.",
  "keywords": [
    "openclaw",
    "plugin",
    "seller",
    "assistant",
    "shopify",
    "ecommerce",
    "commerce",
    "merchant",
    "amazon",
    "operations"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ypyf/openclaw-seller-assistant.git"
  },
  "files": [
    "index.ts",
    "src/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "skills/"
  ],
  "dependencies": {
    "@sinclair/typebox": "^0.34.48"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "test": "node --experimental-strip-types --test src/config.test.ts src/docs.test.ts src/execute.test.ts src/policy.test.ts src/providers/shopify.test.ts src/tools.test.ts",
    "format": "prettier \"**/*.{js,jsx,ts,tsx,json,html,css,md}\" --write",
    "format:check": "prettier \"**/*.{js,jsx,ts,tsx,json,html,css,md}\" --check"
  },
  "devDependencies": {
    "openclaw": "^2026.3.13",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
